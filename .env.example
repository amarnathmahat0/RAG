# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── ChromaDB ────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=nexus_rag

# ── Neo4j ───────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexusrag123

# ── API ─────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_LOG_LEVEL=info

# ── Rate limiting ────────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# ── RAM guardrails ───────────────────────────────────────────────────────────────
MIN_FREE_RAM_MB=1500
RAM_CHECK_INTERVAL_SEC=5

# ── Models ───────────────────────────────────────────────────────────────────────
EMBED_MODEL_PRIMARY=all-minilm:latest
EMBED_MODEL_FALLBACK=mxbai-embed-large:latest
LLM_ROUTER=gemma3:1b
LLM_JUDGE=qwen:1.8b
LLM_GENERATOR=phi3:mini

# ── Retrieval ────────────────────────────────────────────────────────────────────
TOP_K_DENSE=15
TOP_K_SPARSE=15
TOP_K_RERANK=5
RRF_K=60
DENSE_WEIGHT=0.6
SPARSE_WEIGHT=0.4

# ── Chunking ─────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=2

# ── Evaluation ───────────────────────────────────────────────────────────────────
EVAL_RUNS_DIR=./reports/eval_runs
BENCHMARK_PATH=./data/benchmarks/test.json

# ── Tracing ──────────────────────────────────────────────────────────────────────
TRACE_DIR=./reports/traces
METRICS_DIR=./reports/charts

# ── Cache ────────────────────────────────────────────────────────────────────────
CACHE_DIR=./data/cache
CACHE_TTL_SEC=3600
